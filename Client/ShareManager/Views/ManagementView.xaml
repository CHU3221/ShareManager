<Page
    x:Class="ShareManager.App.Views.ManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="RootPage">

    <!-- 🌟 XAML 변수 선언: 여기서 수치를 조절하면 헤더와 리스트가 1:1로 동기화됩니다 -->
    <Page.Resources>
        <GridLength x:Key="ColStatus">70</GridLength>
        <GridLength x:Key="ColShareName">220</GridLength>
        <GridLength x:Key="ColDownload">110</GridLength>
        <GridLength x:Key="ColExpire">120</GridLength>
        <GridLength x:Key="ColPassword">160</GridLength>
        <GridLength x:Key="ColMemo">*</GridLength>
        <!-- *는 남은 공간 자동 채움 -->
        <GridLength x:Key="ColAction">130</GridLength>
    </Page.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid Padding="30" MinWidth="950">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 1. 타이틀 및 상단 액션 버튼 -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="공유 관리" FontSize="28" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    
                    <Button Command="{Binding LoadDataCommand}" ToolTipService.ToolTip="목록 새로고침" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                    </Button>

                    <Button Click="GoToSettings_Click" ToolTipService.ToolTip="환경 설정" VerticalAlignment="Center" Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE713;" FontSize="16"/>
                    </Button>

                    <Button Click="GoToShareSetup_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14"/>
                            <TextBlock Text="새 공유 생성"/>
                        </StackPanel>
                    </Button>
                    
                </StackPanel>
            </Grid>

            <ProgressRing Grid.Row="2" IsActive="{Binding IsLoading}" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center" Canvas.ZIndex="10"/>

            <!-- 📌 2. 고정 헤더 -->
            <!-- 리스트 아이템과 동일한 좌우 Padding(12) 적용 -->
            <Grid Grid.Row="1" Padding="12,10" BorderBrush="LightGray" BorderThickness="0,0,0,1" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{StaticResource ColStatus}"/>
                    <ColumnDefinition Width="{StaticResource ColShareName}"/>
                    <ColumnDefinition Width="{StaticResource ColDownload}"/>
                    <ColumnDefinition Width="{StaticResource ColExpire}"/>
                    <ColumnDefinition Width="{StaticResource ColPassword}"/>
                    <ColumnDefinition Width="{StaticResource ColMemo}"/>
                    <ColumnDefinition Width="{StaticResource ColAction}"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="상태" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="공유 정보" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="2" Text="다운로드" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="만료일" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="다운로드 암호" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="5" Text="메모" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Left"/>
                <TextBlock Grid.Column="6" Text="작업" FontWeight="SemiBold" Foreground="Gray" HorizontalAlignment="Center"/>
            </Grid>

            <!-- 📌 3. 관리 리스트 표 -->
            <ListView Grid.Row="2" ItemsSource="{Binding ShareItems}" SelectionMode="None">

                <!-- 🌟 숨겨진 여백 제거 및 강제 확장(Stretch) 설정 -->
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                        <!-- 이것이 있어야 Grid의 * (남은 공간 채움) 속성이 정상 작동하여 헤더와 완벽히 맞아떨어집니다 -->
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- 헤더와 동일한 좌우 Padding(12) 적용 -->
                        <Grid Padding="12,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{StaticResource ColStatus}"/>
                                <ColumnDefinition Width="{StaticResource ColShareName}"/>
                                <ColumnDefinition Width="{StaticResource ColDownload}"/>
                                <ColumnDefinition Width="{StaticResource ColExpire}"/>
                                <ColumnDefinition Width="{StaticResource ColPassword}"/>
                                <ColumnDefinition Width="{StaticResource ColMemo}"/>
                                <ColumnDefinition Width="{StaticResource ColAction}"/>
                            </Grid.ColumnDefinitions>

                            <!-- 상태 (토글 스위치 삐져나옴 방지: MinWidth="0") -->
                            <ToggleSwitch Grid.Column="0" IsOn="{Binding IsActive, Mode=TwoWay}" OnContent="{x:Null}" OffContent="{x:Null}" MinWidth="0" Margin="0" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                            <!-- 공유 정보 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" ToolTipService.ToolTip="{Binding OriginalName}">
                                <TextBlock Text="{Binding ShareName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding OriginalName}" FontSize="12" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding CreatedAt}" FontSize="11" Foreground="LightGray"/>
                            </StackPanel>

                            <!-- 다운로드 -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentDownloads}" Foreground="#0078D4" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="/" Foreground="Gray" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding MaxDownloadsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" VerticalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>

                            <!-- 만료일 -->
                            <TextBox Grid.Column="3" Text="{Binding ExpireDateText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="무제한" Width="100" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" ToolTipService.ToolTip="YYYY-MM-DD 형식 입력. 비우면 무제한"/>

                            <!-- 암호 덮어쓰기 & 해제 -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Left">
                                <PasswordBox Password="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{Binding PasswordPlaceholder}" Width="120" VerticalAlignment="Center"/>
                                <Button Command="{Binding RemovePasswordCommand}" Visibility="{Binding HasPassword, Mode=OneWay}" ToolTipService.ToolTip="암호 해제" Background="Transparent" BorderThickness="0" Foreground="Red" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE74D;" FontSize="12"/>
                                </Button>
                            </StackPanel>

                            <!-- 메모 -->
                            <TextBox Grid.Column="5" Text="{Binding Memo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="메모 추가" HorizontalAlignment="Stretch" Margin="0,0,15,0" VerticalAlignment="Center"/>

                            <!-- 액션 버튼 그룹 ('작업' 열에 묶음) -->
                            <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Command="{Binding DataContext.SaveChangesCommand, ElementName=RootPage}" CommandParameter="{Binding}" IsEnabled="{Binding IsDirty}" Style="{StaticResource AccentButtonStyle}" ToolTipService.ToolTip="변경사항 저장" Padding="8,6">
                                    <FontIcon Glyph="&#xE74E;" FontSize="16"/>
                                </Button>
                                <Button Command="{Binding DataContext.CopyLinkCommand, ElementName=RootPage}" CommandParameter="{Binding}" ToolTipService.ToolTip="링크 복사" Padding="8,6">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="16"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteShareCommand, ElementName=RootPage}" CommandParameter="{Binding}" Foreground="Red" ToolTipService.ToolTip="공유 삭제" Padding="8,6">
                                    <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </ScrollViewer>
</Page>