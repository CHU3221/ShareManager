<Page
    x:Class="ShareManager.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel Padding="30" Spacing="20" MinWidth="700" MaxWidth="700" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="환경 설정" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10" />

            <InfoBar IsOpen="{Binding ShowError}" Severity="Error" Title="설정 오류" Message="{Binding ErrorMessage}" />
            <InfoBar IsOpen="{Binding ShowSuccess}" Severity="Success" Title="완료" Message="{Binding SuccessMessage}" />

            <ToggleSwitch Header="로컬 스탠드얼론 모드 (앱 내장 서버 사용)" 
                          IsOn="{Binding IsStandaloneMode, Mode=TwoWay}" 
                          OffContent="외부 홈서버 사용" OnContent="로컬 내장 서버 사용" />

            <StackPanel Spacing="15" Margin="0,10,0,0">
                <TextBox Header="서버 IP 주소" Text="{Binding ServerIp, Mode=TwoWay}" 
             IsEnabled="{Binding IsExternalServerMode}" 
             PlaceholderText="예: 192.168.1.100" />

                <TextBox Header="서버 포트" Text="{Binding Port, Mode=TwoWay}" 
             IsEnabled="{Binding IsExternalServerMode}" 
             PlaceholderText="예: 7601" />

                <TextBox Header="API 토큰 (비밀번호)" Text="{Binding ApiKey, Mode=TwoWay}" />

                <TextBox Header="Windows 측 SMB/저장 경로" Text="{Binding SmbBasePath, Mode=TwoWay}" 
             IsEnabled="{Binding IsExternalServerMode}" 
             PlaceholderText="예: \\192.168.1.100\SharedLinks" />
            </StackPanel>

            <Button Content="🗑️ 로컬 공유 데이터 정리" Command="{Binding CleanUpLocalDataCommand}" 
                    Background="Transparent" BorderBrush="Transparent" Foreground="#D13438"
                    HorizontalAlignment="Right" ToolTipService.ToolTip="사용하지 않는 로컬 공유 파일들을 삭제하여 용량을 확보합니다."/>

            <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Button Content="저장 및 적용" Click="OnSaveClicked" Style="{StaticResource AccentButtonStyle}" Width="150"/>
                <Button Content="취소" Command="{Binding CancelCommand}" Width="100"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>