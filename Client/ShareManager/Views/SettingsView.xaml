<Page
    x:Class="ShareManager.App.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="30" Spacing="20" MaxWidth="500" HorizontalAlignment="Left">
        <TextBlock Text="환경 설정" FontSize="24" FontWeight="Bold" Margin="0,0,0,10" />

        <TextBox Header="서버 IP 주소" Text="{Binding ServerIp, Mode=TwoWay}" PlaceholderText="예: 192.168.1.100" />
        <TextBox Header="서버 포트" Text="{Binding Port, Mode=TwoWay}" PlaceholderText="예: 7601" />
        <TextBox Header="API 토큰 (비밀번호)" Text="{Binding ApiKey, Mode=TwoWay}" />
        <TextBox Header="Windows 측 SMB 네트워크 경로" Text="{Binding SmbBasePath, Mode=TwoWay}" PlaceholderText="예: \\192.168.1.100\SharedLinks" />

        <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,20,0,0">
            <Button Content="저장" Command="{Binding SaveCommand}" Style="{StaticResource AccentButtonStyle}" Width="100"/>
            <Button Content="변경하지 않고 나가기" Command="{Binding CancelCommand}" Width="160"/>
        </StackPanel>
    </StackPanel>
</Page>